<% layout("/layouts/boilerplate.ejs") %>

   <body>
      <div class="row mt-3">
         <div class="col-8 offset-3">
            <h3>
               <%= listingdata.title %>
            </h3>
         </div>
      </div>
      <div class="card col-6 offset-3">
         <img src="<%= listingdata.image.url %>" class="card-img-top show-img" alt="listing_image">
         <div class="card-body">
            <p class="card-text">
               Owned by <i>
                  <%= listingdata.owner.username %> <br>
               </i>
               <%= listingdata.description %> <br>
                  <%= listingdata.location %> <br>
                     &#8377; <%= listingdata.price.toLocaleString("en-IN") %> <br>
                        <%= listingdata.country %> <br>
            </p>
         </div>
      </div>
      <% if(curruser && curruser._id.equals(listingdata.owner._id)) {%>
         <div class="mb-3">
            <a class="btn btn-dark col-1 offset-3 btn-new  " href="/listing/<%= listingdata.id %>/edit">edit</a>
            <a class="btn btn-dark" href="/listing/<%= listingdata.id %>/delete">delete</a>
         </div>
         <% } %>

            <div>
               <hr>
               <h4>Leave a Review</h4>
               <form action="/listing/<%= listingdata.id %>/reviews" method="post" novalidate class="needs-validation">
                  <div class="mt-3 mb-3">
                     <label for="rating">Rate our place</label>
                     <input name="Review[rating]" type="range" min="1" max="5" class="form-control" required>
                     <div class="invalid-feedback">Enter Ratings</div>
                  </div>

                  <div class="mt-3 mb-3">
                     <label for="rating">Feedaback</label>
                     <textarea cols="30" rows="5" name="Review[comments]" class="form-control" id=""
                        required></textarea>
                     <div class="invalid-feedback">Enter Review</div>
                  </div>

                  <button type="submit" class="btn btn-outline-dark mb-3">Sumbit</button>
               </form>

               <hr>

               <div class="row pt-3">
                  <% for(Review of listingdata.Review){ %>
                     <div class="card col-5 ms-5  mb-3">
                        <div class="card-body">
                           <h5 class="card-title">Core Mem</h5>
                           <p class="card-body">
                              <%= Review.comments %>
                           </p>
                           <p class="card-body">
                              <%= Review.rating %>
                                 <% for(let i=0;i<Review.rating;i++){ %>
                                    &#11088;
                                    <% } %>
                           </p>

                           <form method="post"
                              action="/listing/<%= listingdata.id %>/reviews/<%= Review._id %>?_method=DELETE">
                              <button class="btn btn-sm btn-dark">Delete</button>
                           </form>

                        </div>
                     </div>
                     <% } %>
               </div>
            </div>
   </body>