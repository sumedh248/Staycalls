<% layout("/layouts/boilerplate.ejs") %>

   <body>
      <div class="row mt-3">
         <div class="col-8 offset-2">
            <h3>fill edits</h3>
            <form method="POST" action="/listing/<%= listing1.id %>?_method=PUT"  novalidate class="needs-validation">
               <div class="mb-3">
                  <label for="Title" class="form-label">Title</label>
                  <input type="text" value="<%= listing1.title %>" name="listing[title]" class="form-control" required>
                  <div class="valid-feedback">Title looks good</div>
               </div>
               <div class="mb-3">
                  <label for="description" class="form-label">Description</label>
                  <textarea type="text" name="listing[description]"
                     class="form-control" required><%= listing1.description %></textarea>
                     <div class="invalid-feedback">Enter Description</div>
               </div>
               <div class="mb-3">
                  <label for="Image Link" class="form-label">Image Link</label>
                  <input type="text" value="<%= listing1.image.url%>" class="form-control" name="listing[img]" required>
                  <div class="invalid-feedback">Enter image link</div>
               </div>
               <div class="row">
               <div class="col-md-4 mb-3">
                  <label for="Price" class="form-label">Price</label>
                  <input type="number" value="<%= listing1.price %>" name="listing[price]" class="form-control" required>
                  <div class="invalid-feedback">Enter price</div>
               </div>
               <div class="col-md-8 mb-3">
                  <label for="Country" class="form-label">Country</label>
                  <input type="text" value="<%= listing1.country %>" name="listing[country]" class="form-control" required>
                  <div class="invalid-feedback">Enter country</div>
               </div>
               </div>
               <div class="mb-3">
                  <label for="Location" class="form-label">Location</label>
                  <input type="text" value="<%= listing1.location %>" name="listing[location]" class="form-control" required>
                  <div class="invalid-feedback">Enter location</div>
               </div>
               <button type="submit" class="btn btn-dark btn-edit mt-3 mb-3">save data</button>
               
            </form>
         </div>
      </div>
   </body>